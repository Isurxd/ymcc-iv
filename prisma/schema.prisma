generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "rhel-openssl-1.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  password      String?        // Boleh null jika login OAuth/Firebase 
  name          String
  role          String         @default("USER") // enum Role didukung via string di SQLite
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  
  registrations Registration[]
  articles      Article[]
}

model Event {
  id          String         @id @default(uuid())
  name        String         // Mining Games, MSIC, Paper, dll
  description String?
  startDate   DateTime
  endDate     DateTime
  createdAt   DateTime       @default(now())

  registrations Registration[]
  exams         Exam[]
  attendances   Attendance[]
}

model Registration {
  id        String             @id @default(uuid())
  userId    String
  eventId   String
  status    String             @default("PENDING_PAYMENT") // enum RegistrationStatus
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  payment   Payment?
  documents Document[]
  examAttempts ExamAttempt[]
  attendances  Attendance[]
}

model Payment {
  id             String       @id @default(uuid())
  registrationId String       @unique
  amount         Float
  proofUrl       String       // URL file bukti transfer
  verifiedAt     DateTime?
  createdAt      DateTime     @default(now())

  registration   Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
}

model Document {
  id             String       @id @default(uuid())
  registrationId String
  fileName       String
  fileUrl        String       
  isVerified     Boolean      @default(false)
  notes          String?      
  createdAt      DateTime     @default(now())

  registration   Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
}

model Exam {
  id          String         @id @default(uuid())
  eventId     String
  title       String
  description String?
  durationMin Int            @default(120) 
  createdAt   DateTime       @default(now())
  
  event       Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  questions   Question[]
  attempts    ExamAttempt[]
}

model Question {
  id          String   @id @default(uuid())
  examId      String
  content     String   
  options     String?  // SQLite tidak dukung JSON default (menggunakan String representation)
  answerKey   String   
  points      Int      @default(1)
  
  exam        Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
}

model ExamAttempt {
  id              String       @id @default(uuid())
  registrationId  String
  examId          String
  startTime       DateTime     @default(now())
  endTime         DateTime?    
  score           Int?         
  cheatCount      Int          @default(0) 
  answers         String?      // SQLite fallback for JSON
  status          String       @default("IN_PROGRESS") 
  
  registration    Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  exam            Exam         @relation(fields: [examId], references: [id], onDelete: Cascade)
}

model Product {
  id          String   @id @default(uuid())
  name        String
  description String
  price       Float
  imageUrl    String
  variants    ProductVariant[]
}

model ProductVariant {
  id        String   @id @default(uuid())
  productId String
  size      String   
  stock     Int      @default(0)
  
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]
}

model Order {
  id              String   @id @default(uuid())
  customerName    String
  customerEmail   String
  customerPhone   String
  shippingAddress String
  status          String   @default("PENDING_PAYMENT") 
  totalAmount     Float
  receiptUrl      String?     
  
  // Xendit & Biteship integration fields
  xenditInvoiceId String?
  paymentUrl      String?
  biteshipOrderId String?
  trackingNumber  String?
  shippingCourier String?
  shippingCost    Float?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  items           OrderItem[]
}

model OrderItem {
  id          String   @id @default(uuid())
  orderId     String
  variantId   String
  quantity    Int
  priceAtBuy  Float
  
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant     ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)
}

model Article {
  id          String   @id @default(uuid())
  title       String
  content     String   
  thumbnailUrl String?
  authorId    String
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author      User     @relation(fields: [authorId], references: [id])
}

model Attendance {
  id             String       @id @default(uuid())
  registrationId String
  eventId        String
  status         String       @default("VALID") 
  scannedById    String?      
  createdAt      DateTime     @default(now())
  
  registration   Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  event          Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
}
